# ==========================
# SERVIDOR
# ==========================

SERVER_PATH=/
PORT=8080


# ==========================
# POOL DE CONEXIONES
# ==========================

CONNECTION_TIMEOUT=10000
MAXIMUM_POOL_SIZE=10