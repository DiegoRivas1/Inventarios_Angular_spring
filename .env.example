DB_USERNAME=your_user
DB_PASSWORD=your_password

DB_URL=jdbc:mysql://localhost:3306/inventario_db?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true


